# Copy this file to .env for local development.
# Never commit real secrets or provider credentials.

COMPOSE_PROJECT_NAME=vdt2026

# PostgreSQL
POSTGRES_DB=omnicare
POSTGRES_USER=omnicare
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_DEDUP_TTL_SECONDS=86400

# Kafka
KAFKA_HOST_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# Application ports
INBOX_SERVICE_PORT=8080
CHANNEL_SERVICE_PORT=8081
FRONTEND_PORT=5173
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Demo authentication
DEMO_AGENT_EMAIL=agent@example.test
DEMO_AGENT_PASSWORD=change-me-local-only
JWT_SECRET=replace-with-a-long-random-local-secret

# Facebook adapter placeholders
FACEBOOK_MODE=simulator
FACEBOOK_PAGE_ID=local-page-id
FACEBOOK_APP_SECRET=replace-with-real-secret-outside-git
FACEBOOK_VERIFY_TOKEN=replace-with-real-token-outside-git
FACEBOOK_PAGE_ACCESS_TOKEN=replace-with-real-token-outside-git

# Email adapter placeholders
EMAIL_MODE=simulator
IMAP_HOST=localhost
IMAP_PORT=1143
IMAP_USERNAME=demo@example.test
IMAP_PASSWORD=replace-with-real-password-outside-git
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=demo@example.test
